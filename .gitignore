# Projects directory - Work-in-progress projects are usually not version controlled.
# For this FeGenie/Codex test, keep the source PNG and generated project files trackable.
projects/*
!projects/README.md
!projects/FeGenie.png
!projects/fegenie/
!projects/fegenie/**

# Keep PPT Master exports visible for Codex/GitHub PR download.
!exports/
!exports/**
!*.pptx
